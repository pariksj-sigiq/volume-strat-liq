{
  "name": "liq-sweep",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test",
    "web:dev": "vite --config web/vite.config.ts --host 127.0.0.1 --port 5173",
    "web:build": "vite build --config web/vite.config.ts",
    "web:typecheck": "tsc -p web/tsconfig.json --noEmit",
    "web:check": "npm run web:typecheck && npm run web:build",
    "fetch:upstox": "node scripts/upstox_backfill.mjs",
    "fetch:upstox:intraday": "node scripts/upstox_intraday_backfill.mjs",
    "fetch:upstox:signal-options": "node scripts/upstox_signal_options_backfill.mjs",
    "dashboard:serve": "python3 -m app.server"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lightweight-charts": "^5.0.8",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
